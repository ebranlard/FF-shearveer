# --------------------------------------------------------------------------------
# --- MAIN RULES 
# --------------------------------------------------------------------------------

all: compile copy test
# all: compile test

$(BUILD_DIR):
	@echo "------------------------------------------------------------"
	mkdir $(BUILD_DIR)

compile: $(BUILD_DIR)
	@echo "------------------------------------------------------------"
	@echo "---- Compiling $(MAKE_TARGET)$(EXE_SUFFIX)  in: $(BUILD_DIR)"
	@echo "------------------------------------------------------------"
ifeq ($(strip $(QUICK)),1)
	cd $(BUILD_DIR) && $(MAKE) $(MAKE_ARGS) $(MAKE_TARGET)
else
	cd $(BUILD_DIR) && cmake $(CMAKE_ARGS) ../OpenFAST && $(MAKE) $(MAKE_ARGS) $(MAKE_TARGET)
endif

clean:
	cd $(BUILD_DIR) && $(MAKE) clean

copy:
	echo "Running: $(COPY) $(DRIVEREXE) $(basename $(notdir $(DRIVEREXE)))$(EXE_SUFFIX)$(EXEEXT)"
	@echo "---------------------------------------------------"
	$(COPY) $(DRIVEREXE) $(basename $(notdir $(DRIVEREXE)))$(EXE_SUFFIX)$(EXEEXT)
	$(COPY) $(DRIVEREXE) $(TEST_DIR)$(SLASH)$(basename $(notdir $(DRIVEREXE)))$(EXE_SUFFIX)$(EXEEXT)

test:
ifeq ($(strip $(UTEST)),1)
	@echo "------------------- UNIT TESTS ---------------------------------"
	./$(UTEST_EXE)
endif
ifeq ($(strip $(CTEST)),1)
	@echo "------------------- CTEST --------------------------------------"
	cd "$(BUILD_DIR)" && ctest $(CTEST_ARGS)
else ifeq ($(strip $(CTEST)),0)
	make -C $(TEST_DIR) 
else
	@echo "------------------- USER TESTS (CTEST=2) -----------------------"
	cd $(TEST_DIR) && ./$(DRIVEREXE2) $(TEST_FILE)
endif

test2:
	cd $(TEST_DIR)/.. && python PostPro.py

$(BUILD_DOCDIR):
	@echo "------------------------------------------------------------"
	mkdir $(BUILD_DOCDIR)

doc: $(BUILD_DOCDIR)
	cd $(BUILD_DOCDIR) && cmake -DBUILD_DOCUMENTATION=ON ..  && $(MAKE) sphinx-pdf


