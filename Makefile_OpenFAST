suffix=
ifeq ($(WSL),1)
suffix=-linux
endif
ifeq ($(strip $(DOUBLE)),1)
    CMAKE_ARGS+= -DDOUBLE_PRECISION:BOOL=ON
	suffix:=$(suffix)-double
	EXE_SUFFIX_BASE=_x64d_
else ifeq ($(strip $(DOUBLE)),0)
    CMAKE_ARGS+= -DDOUBLE_PRECISION:BOOL=OFF
	suffix:=$(suffix)-single
	EXE_SUFFIX_BASE=_x64s_
else
    $(error Bad DOUBLE variable)
endif
ifeq ($(strip $(RELEASE)),1)
    CMAKE_ARGS+= -DCMAKE_BUILD_TYPE=Release
	suffix:=$(suffix)-release
else ifeq ($(strip $(RELEASE)),0)
    CMAKE_ARGS+= -DCMAKE_BUILD_TYPE=Debug
	suffix:=$(suffix)-debug
	EXE_SUFFIX_BASE:=$(EXE_SUFFIX_BASE)debug_
else
    $(error Bad RELEASE variable)
endif
BRANCH:= $(shell git rev-parse --abbrev-ref HEAD)
BRANCH:= $(subst /,-,$(BRANCH))
EXE_SUFFIX:=$(EXE_SUFFIX_BASE)$(BRANCH)_$(DATE)$(EXE_SUFFIX)
DRIVEREXE2=$(basename $(notdir $(DRIVEREXE)))$(EXE_SUFFIX)$(EXEEXT)

ifeq ($(OS),Windows_NT)
	OS=Windows
	CMAKE_ARGS:=$(CMAKE_ARGS) -G"MinGW Makefiles"
	MAKE=make
	# --- Using intel fortran and nmake
	#suffix:=-nmake$(suffix)
	#CMAKE_ARGS=$(CMAKE_ARGS) -G"NMake Makefiles"
	
	RMDIR=rmdir /S /Q
	LIBEXT='.dll'
	EXEEXT=.exe
	#COPY=copy /Y
	COPY=cp
	SLASH=\\
else
    OS=$(shell uname -s)
    ifeq ($(OS),Linux)
		# ISSUE WITH CMAKE PICKING UP F95 TODO
		FC=/usr/bin/gfortran
		LIBEXT='.so'
		LIBPRE='lib'
    else ifeq ($(OS),Darwin)
		LIBEXT='.dylib'
    endif
	RMDIR=rm -rf
	COPY=cp
endif
