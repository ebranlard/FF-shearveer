else ifeq ($(strip $(DRIVER)),4)
    MAKE_TARGET= hydrodyn_driver
    DRIVEREXE=$(BUILD_DIR)\modules\hydrodyn\hydrodyn_driver$(EXEEXT)
    CTEST_ARGS=-R hd_* --verbose --stop-on-failure --extra-verbose
else ifeq ($(strip $(DRIVER)),5)
    MAKE_TARGET= FAST.Farm
    DRIVEREXE=$(BUILD_DIR)$(SLASH)glue-codes$(SLASH)fast-farm$(SLASH)Fast.Farm$(EXEEXT)
    CMAKE_ARGS+=-DBUILD_FASTFARM:BOOL=ON
    CTEST_ARGS= -L fastfarm --verbose --stop-on-failure --extra-verbose
else ifeq ($(strip $(DRIVER)),6)
    MAKE_TARGET= beamdyn_driver
    DRIVEREXE=$(BUILD_DIR)\modules\beamdyn\beamdyn_driver$(EXEEXT)
    CTEST_ARGS=-R bd_* --verbose --stop-on-failure --extra-verbose
else
    MAKE_TARGET= openfast
    DRIVEREXE=$(BUILD_DIR)\glue-codes\openfast\openfast$(EXEEXT)
