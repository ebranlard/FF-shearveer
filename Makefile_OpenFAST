    DRIVEREXE=$(BUILD_DIR)\modules\aerodyn\libaerodyn_inflow_c_binding.dll
    CTEST_ARGS=-R py_ad* --verbose --stop-on-failure --extra-verbose
else ifeq ($(strip $(DRIVER)),3)
